# Environment Configuration for ClarityCareers

# Database
# For MySQL (default):
DATABASE_URL=mysql://root:password@localhost:3306/claritycareers
# For PostgreSQL (alternative):
# DATABASE_URL=postgresql://postgres:password@localhost:5432/claritycareers

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Model Path (optional - uses baseline if not found)
MODEL_PATH=../models/fine-tuned-sbert

# Server
HOST=0.0.0.0
PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
